# ============================
# Terminal CodingAgent 配置
# ============================

# ── LLM 配置 ──
# 至少配置一个 LLM provider
ANTHROPIC_API_KEY=你的Anthropic_API_Key
OPENAI_API_KEY=你的OpenAI_API_Key

# 选择默认使用的 provider + model
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514

# ── 数据库配置 ──
# Chroma 向量库存储路径
CHROMA_PERSIST_DIR=./data/chroma

# SQLite 结构化存储路径
SQLITE_DB_PATH=./data/app.db

# LangGraph Checkpointer（会话断点恢复）
CHECKPOINT_DB_PATH=./data/checkpoints.db

# ── 日志配置 ──
LOG_LEVEL=INFO
LOG_FORMAT=text  # text 或 json

# ── API 配置 ──
API_HOST=0.0.0.0
API_PORT=8000

# ── 可视化配置 ──
DASHBOARD_PORT=8501

# ── Skill 配置 ──
SKILL_DIRS=./skills:~/.pi-agent/skills

# ── MCP 配置 ──
MCP_CONFIG_PATH=./config/mcp_servers.yaml

# ── 多模型配置（可选）──
# 为不同 Agent 配置不同的模型，实现 Maker-Checker 等场景
# 格式: LLM_PROFILE_<PROFILE_NAME>_<FIELD>=value
# 可用字段: provider, model, base_url, api_key, temperature

# 示例：coder 用 deepseek，reviewer 用 sensenova
LLM_PROFILE_DEEPSEEK_PROVIDER=openai
LLM_PROFILE_DEEPSEEK_MODEL=deepseek-chat
LLM_PROFILE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_PROFILE_DEEPSEEK_API_KEY=your_deepseek_key

LLM_PROFILE_SENSENOVA_PROVIDER=openai
LLM_PROFILE_SENSENOVA_MODEL=sensenova-6.7-flash-lite
LLM_PROFILE_SENSENOVA_BASE_URL=https://token.sensenova.cn/v1

# Agent 模型映射（格式: LLM_AGENT_MODEL_<AGENT_NAME>=profile_name）
LLM_AGENT_MODEL_CODER=deepseek
LLM_AGENT_MODEL_REVIEWER=sensenova
LLM_AGENT_MODEL_TESTER=sensenova
LLM_AGENT_MODEL_RESEARCHER=deepseek
LLM_AGENT_MODEL_ORCHESTRATOR=deepseek
